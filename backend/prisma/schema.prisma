generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  postId    String   @db.ObjectId
  content   String
  createdAt DateTime @default(now())
  post      post     @relation(fields: [postId], references: [id])
  user      user     @relation(fields: [userId], references: [id])
}

model creator {
  id                 String            @id @default(auto()) @map("_id") @db.ObjectId
  userId             String            @unique @db.ObjectId
  bio                String?
  avatar             String?
  coverImage         String?
  subscriptionPrice  Float             @default(4.99)
  isKycVerified      Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  idNumber           String?
  kycDocument        String?
  kycRejectionReason String?
  kycStatus          creator_kycStatus @default(NOT_SUBMITTED)
  bankAccountNumber  String?
  bankIfscCode       String?
  panCardNumber      String?
  user               user              @relation(fields: [userId], references: [id])
  payment            payment[]
  post               post[]
  subscription       subscription[]
  tip                tip[]
  withdrawal         withdrawal[]
}

model follow {
  id                            String @id @default(auto()) @map("_id") @db.ObjectId
  followerId                    String @db.ObjectId
  followingId                   String @db.ObjectId
  user_follow_followerIdTouser  user   @relation("follow_followerIdTouser", fields: [followerId], references: [id])
  user_follow_followingIdTouser user   @relation("follow_followingIdTouser", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model globalsetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model like {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  postId String @db.ObjectId
  post   post   @relation(fields: [postId], references: [id])
  user   user   @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model media {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String?  @db.ObjectId
  messageId String?  @db.ObjectId
  url       String
  type      String
  blurHash  String?
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
  message   message? @relation(fields: [messageId], references: [id])
  post      post?    @relation(fields: [postId], references: [id])
}

model message {
  id                            String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId                      String   @db.ObjectId
  receiverId                    String   @db.ObjectId
  content                       String?
  isPaid                        Boolean  @default(false)
  price                         Float?
  isUnlocked                    Boolean  @default(false)
  createdAt                     DateTime @default(now())
  media                         media[]
  user_message_receiverIdTouser user     @relation("message_receiverIdTouser", fields: [receiverId], references: [id])
  user_message_senderIdTouser   user     @relation("message_senderIdTouser", fields: [senderId], references: [id])
}

model notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  type      String
  title     String
  content   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id])
}

model payment {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  userId            String         @db.ObjectId
  amount            Float
  type              payment_type
  status            payment_status @default(PENDING)
  createdAt         DateTime       @default(now())
  creatorAmount     Float          @default(0)
  creatorId         String?        @db.ObjectId
  platformFee       Float          @default(0)
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  creator           creator?       @relation(fields: [creatorId], references: [id])
  user              user           @relation(fields: [userId], references: [id])
}

model post {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  creatorId String    @db.ObjectId
  content   String?
  type      post_type @default(SUBSCRIBER)
  price     Float?
  published Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  comment   comment[]
  like      like[]
  media     media[]
  creator   creator   @relation(fields: [creatorId], references: [id])
}

model subscription {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  fanId            String   @db.ObjectId
  creatorId        String   @db.ObjectId
  status           String   @default("active")
  currentPeriodEnd DateTime
  createdAt        DateTime @default(now())
  creator          creator  @relation(fields: [creatorId], references: [id])
  user             user     @relation(fields: [fanId], references: [id])

  @@unique([fanId, creatorId])
}

model tip {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fanId     String   @db.ObjectId
  creatorId String   @db.ObjectId
  amount    Float
  message   String?
  createdAt DateTime @default(now())
  creator   creator  @relation(fields: [creatorId], references: [id])
  user      user     @relation(fields: [fanId], references: [id])
}

model user {
  id                               String         @id @default(auto()) @map("_id") @db.ObjectId
  email                            String         @unique
  password                         String
  name                             String?
  role                             user_role      @default(FAN)
  isVerified                       Boolean        @default(false)
  createdAt                        DateTime       @default(now())
  updatedAt                        DateTime       @updatedAt
  isDeleted                        Boolean        @default(false)
  isActive                         Boolean        @default(true)
  comment                          comment[]
  creator                          creator?
  follow_follow_followerIdTouser   follow[]       @relation("follow_followerIdTouser")
  follow_follow_followingIdTouser  follow[]       @relation("follow_followingIdTouser")
  like                             like[]
  message_message_receiverIdTouser message[]      @relation("message_receiverIdTouser")
  message_message_senderIdTouser   message[]      @relation("message_senderIdTouser")
  notification                     notification[]
  payment                          payment[]
  subscription                     subscription[]
  tip                              tip[]
  wallet                           wallet?
}

model wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id])
}

model withdrawal {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  creatorId     String            @db.ObjectId
  amount        Float
  status        withdrawal_status @default(PENDING)
  payoutMethod  String
  payoutDetails String
  processedAt   DateTime?
  createdAt     DateTime          @default(now())
  creator       creator           @relation(fields: [creatorId], references: [id])
}

enum payment_type {
  SUBSCRIPTION
  TIP
  PAID_POST
  WALLET_DEPOSIT
}

enum post_type {
  PUBLIC
  SUBSCRIBER
  PAID
}

enum withdrawal_status {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum payment_status {
  PENDING
  SUCCESS
  FAILED
}

enum user_role {
  FAN
  CREATOR
  ADMIN
}

enum creator_kycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}
